# Biro AI Configuration Example
# Copy this to .env and fill in your keys

# 1 = OpenAI
# 2 = Google Gemini
# 3 = DeepSeek
# 4 = Anthropic
# 5 = OpenRouter
# 6 = Groq
PROVIDER=2

# AI Tier Selection
# 1 = Free models (Default)
# 2 = Paid/Premium models
AI_TIER=1

# API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional: Model Overrides
# Tier 1 (Free) Defaults:
# - OpenRouter: google/gemma-4-31b-it:free
# - Groq: llama-3.3-70b-versatile
# - Gemini: gemini-1.5-flash

# Tier 2 (Paid) Defaults:
# - OpenRouter: anthropic/claude-3.5-sonnet
# - Groq: openai/gpt-oss-120b
# - Gemini: gemini-1.5-pro

# Manual Overrides:
# OPENROUTER_MODEL=
# GROQ_MODEL=
# GEMINI_MODEL=
# OPENAI_MODEL=
# DEEPSEEK_MODEL=
# ANTHROPIC_MODEL=
